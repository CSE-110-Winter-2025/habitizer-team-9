<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.tasks.TaskListFragment">

    <!-- Timer TextView -->
    <TextView
        android:id="@+id/timerTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Routine Name TextView -->
    <TextView
        android:id="@+id/routine_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Routine Name"
        android:textColor="@android:color/holo_blue_dark"
        android:textSize="48sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/timerTextView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Mock Mode Toggle Button -->
    <ToggleButton
        android:id="@+id/mockModeToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textOn="Mock Mode ON"
        android:textOff="Mock Mode OFF"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/routine_name"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Advance Time Button -->
    <Button
        android:id="@+id/advanceTimeButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Advance Time by 30s"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/mockModeToggle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
